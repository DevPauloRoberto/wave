# ============================================================
# Wave - Variáveis de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha os valores.
#   cp .env.example .env
# ============================================================

# ── Banco de Dados (MySQL) ────────────────────────
# Em Docker, DB_HOST deve ser "db" (nome do serviço no compose)
# Localmente, use "localhost" ou "127.0.0.1"
DB_HOST=db
DB_USER=wave_user
DB_PASS=wave_pass
DB_NAME=wave
DB_ROOT_PASS=rootpass

# Sync de tabelas (true = cria/altera tabelas ao iniciar | false = não mexe)
# Use true só na primeira vez ou ao alterar models
DB_SYNC=false

# ── Autenticação ──────────────────────────────────
JWT_SECRET=troque-este-segredo-por-algo-forte
JWT_EXPIRES_IN=2h

# ── Ambiente ──────────────────────────────────────
NODE_ENV=production